# ============================================
# FreshSip Juice Bar - Environment Variables
# ============================================

# Database Configuration
# 
# Option 1: Neon (Recommended - Free Forever)
# Get from: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
# Example: postgresql://user:pass@ep-cool-123.ap-south-1.aws.neon.tech/freshsip?sslmode=require
#
# Option 2: Render PostgreSQL (Free for 90 days)
# Get from: https://dashboard.render.com
# Format: postgresql://user:password@host/database
#
# Option 3: Railway MySQL (if using MySQL)
# Format: mysql://user:password@host:port/database
#
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Secret for session tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production

# Manus OAuth Configuration (if using Manus)
VITE_APP_ID=manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Razorpay Payment Gateway Configuration
# Get from https://dashboard.razorpay.com/settings/api-keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-domain.railway.app

# Optional: Built-in API Configuration (if using Manus)
BUILT_IN_FORGE_API_KEY=your-api-key
BUILT_IN_FORGE_API_URL=https://api.manus.im

# Optional: Owner Information
OWNER_NAME=Your Name
OWNER_OPEN_ID=your-open-id

# Optional: Analytics (if using Manus Analytics)
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# Optional: Frontend API Keys
VITE_FRONTEND_FORGE_API_KEY=your-frontend-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
